# ─── Server ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# ─── Data ────────────────────────────────────────────────────
DATA_DIR=data/sources

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Security ────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
BODY_MAX_SIZE=10kb
TRUST_PROXY=false

# ─── Web App ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
