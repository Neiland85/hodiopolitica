{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": ".",
    "outDir": "../../dist/api",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "composite": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"],
  "references": [
    { "path": "../../packages/engine" },
    { "path": "../../packages/contracts" }
  ]
}
