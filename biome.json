{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noForEach": "off"
      },
      "suspicious": {
        "noExplicitAny": "warn"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useConst": "error"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "files": {
    "includes": ["packages/**/*.ts", "apps/api/**/*.ts", "apps/web/app/**/*.ts", "apps/web/app/**/*.tsx"]
  }
}
